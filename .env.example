# Christopher — Environment Configuration
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# Run christopher_install.sh first — it builds llama.cpp/whisper.cpp
# and downloads the model, then creates a .env with correct paths.

# ── LLM (llama-server) ────────────────────────────────────────────────────────

# Path to llama-server binary
# t3610: /data/projects/llama.cpp/build/bin/llama-server
# fresh install: ~/llama.cpp/build/bin/llama-server (built by christopher_install.sh)
LLAMA_SERVER_BIN=/data/projects/llama.cpp/build/bin/llama-server

# GGUF model file. Llama 3.2 3B recommended for 4GB VRAM; Mistral 7B for 8GB+
# t3610: /data/models/Llama-3.2-3B-Instruct-Q4_K_M.gguf
LLAMA_MODEL=/data/models/Llama-3.2-3B-Instruct-Q4_K_M.gguf
# LLAMA_MODEL=/data/models/mistral-7b-instruct-v0.2.Q4_K_M.gguf

# URL where llama-server listens (leave as-is unless you changed the port)
LLAMA_SERVER_URL=http://localhost:8080

# GPU layers to offload. 99 = all layers (works if model fits in VRAM)
# 4GB VRAM (GTX 1050 Ti): use 28 for Mistral 7B, 99 for Llama 3.2 3B
LLAMA_NGL=99

# CPU threads for non-GPU layers
LLAMA_THREADS=4

# Context window size in tokens
LLAMA_CTX=2048

# ── Speech Recognition (whisper.cpp) ──────────────────────────────────────────

WHISPER_BIN=~/whisper.cpp/build/bin/whisper-cli
WHISPER_MODEL=~/whisper.cpp/models/ggml-base.en.bin

# ── Text-to-Speech (Piper) ────────────────────────────────────────────────────

# Leave blank to use 'piper' from PATH (default after pip install piper-tts)
PIPER_BIN=

PIPER_MODEL=~/piper_models/en_US-libritts-high.onnx
PIPER_CONFIG=~/piper_models/en_US-libritts-high.onnx.json

# ── FusionAL MCP Servers ──────────────────────────────────────────────────────

# Shared API key — must match FUSIONAL_API_KEY in mcp-consulting-kit .env files
# Generate with: python3 -c "import secrets; print(secrets.token_hex(16))"
FUSIONAL_API_KEY=changeme

# MCP server endpoints (use SSH tunnel ports if connecting from Windows)
FUSIONAL_BI_URL=http://localhost:8101
FUSIONAL_API_URL=http://localhost:8102
FUSIONAL_CONTENT_URL=http://localhost:8103

# ── Voice Recording ───────────────────────────────────────────────────────────

# Seconds to record per voice turn
LISTEN_SECONDS=5

# ── Audio (WSL2 only) ─────────────────────────────────────────────────────────
# If running in WSL2, set PULSE_SERVER to point at Windows PulseAudio:
#   export PULSE_SERVER=tcp:$(awk '/^nameserver / {print $2; exit}' /etc/resolv.conf):4713
# Or set it here (note: WSL2 IP changes on each reboot):
# PULSE_SERVER=tcp:172.24.128.1:4713
